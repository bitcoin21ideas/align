        "jsCode": "const memoryEntries = $('Parse Output').item.json.memoryEntries || '';\nconst existingIndex = $('Decode').item.json.memoryIndex || '';\nconst indexSHA = $('Decode').item.json.memoryIndexSHA || '';\n\n// No entries written this session\nif (!memoryEntries || memoryEntries.trim() === '(no memory entries today)') {\n  return [{ json: { hasNewEntries: false, updatedIndex: existingIndex, indexSHA } }];\n}\n\nconst newLines = [];\nconst blocks = memoryEntries.split(/(?=###\\s+\\d{8}-)/g).filter(b => b.trim());\n\nfor (const block of blocks) {\n  const idMatch       = block.match(/###\\s+(\\d{8}-[\\w-]+)/);\n  const typeMatch     = block.match(/- type:\\s*(\\w+)/);\n  const projectMatch  = block.match(/- project:\\s*(.+)/);\n  const entryMatch    = block.match(/- entry:\\s*(.+)/);\n  const supersedesMatch = block.match(/- supersedes:\\s*(\\S+)/);\n\n  if (idMatch && typeMatch && projectMatch && entryMatch) {\n    const id         = idMatch[1].trim();\n    const type       = typeMatch[1].trim();\n    const project    = projectMatch[1].trim();\n    const raw        = entryMatch[1].trim();\n    const summary    = raw;\n    const supersedes = supersedesMatch ? supersedesMatch[1].trim() : '—';\n    const affects    = '—'; // populated in a future phase\n\n    newLines.push(`${id} | ${type} | ${project} | ${summary} | ${supersedes} | ${affects}`);\n  }\n}\n\nif (newLines.length === 0) {\n  return [{ json: { hasNewEntries: false, updatedIndex: existingIndex, indexSHA } }];\n}\n\nconst header = '<!-- v1: id | type | project | summary | supersedes | affects -->';\nconst base = (!existingIndex || existingIndex === '(no entries yet)') ? header : existingIndex;\nconst updatedIndex = base.trimEnd() + '\\n' + newLines.join('\\n') + '\\n';\n\nreturn [{ json: { hasNewEntries: true, updatedIndex, indexSHA } }];"
      },
