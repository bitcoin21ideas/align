        "jsCode": "const binaryData = items[0].json.content;\nconst decoded = Buffer.from(binaryData, 'base64').toString('utf-8');\n\nreturn [{\n  json: {\n    rollingContext: decoded,\n    transcript: $('Get transcript').item.json.transcript,\n    today: new Date().toISOString().slice(0, 10)\n  }\n}];"
