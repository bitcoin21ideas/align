    {
      "parameters": {
        "jsCode": "if (!items[0].json.results) {\n  return [{json: {transcript: \"Error: No transcription returned\"}}];\n}\n\nconst alternatives = items[0].json.results.channels[0].alternatives[0];\nconst transcript = alternatives.paragraphs?.transcript || alternatives.transcript;\n\nreturn [{json: {transcript}}];"
      },
