      "parameters": {
        "jsCode": "// Handover\nconst handoverRaw = $('Get handover').item.json;\nconst rollingContext = Buffer.from(handoverRaw.content, 'base64').toString('utf-8');\n\n// Projects registry — graceful fallback if file missing\nlet projectRegistry = '(no project registry)';\nlet tagList = '#misc, #personal';\nconst projectsRaw = $('Get _projects').item.json;\nif (projectsRaw && projectsRaw.content) {\n  projectRegistry = Buffer.from(projectsRaw.content, 'base64').toString('utf-8').trim();\n  const tagMatches = [...projectRegistry.matchAll(/\\|\\s*`(#\\w+)`\\s*\\|/g)];\n  if (tagMatches.length) tagList = tagMatches.map(m => m[1]).join(', ');\n}\n\n// Memory index — direct input (from Get memory index)\nlet memoryIndex = '(no entries yet)';\nlet memoryIndexSHA = '';\nif (items[0].json.content) {\n  memoryIndex = Buffer.from(items[0].json.content, 'base64').toString('utf-8').trim();\n  memoryIndexSHA = items[0].json.sha || '';\n}\n\n// Inject tag list into system prompt\nconst rawPrompt = $('Decode prompt').item.json.prompt;\nconst augmentedPrompt = rawPrompt.replace('{{PROJECT_TAGS}}', tagList);\n\nreturn [{\n  json: {\n    rollingContext,\n    projectRegistry,\n    memoryIndex,\n    memoryIndexSHA,\n    transcript: $('Get transcript').item.json.transcript,\n    today: new Date().toISOString().slice(0, 10),\n    augmentedPrompt\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1312,
        64
      ],
      "id": "5b20c1a3-34b2-4a00-9965-13eabd97af2f",
      "name": "Decode"
    },
    {
      "parameters": {
        "jsCode": "const raw = items[0].json.content.parts[0].text;\n\nconst parts = raw.split('===ROLLING_UPDATE===');\nif (parts.length < 2) {\n  throw new Error('Missing ===ROLLING_UPDATE=== delimiter — check Gemini output');\n}\n\nconst rollingAndRest = parts[1].split('===ARCHIVE_ENTRIES===');\nif (rollingAndRest.length < 2) {\n  throw new Error('Missing ===ARCHIVE_ENTRIES=== delimiter — check Gemini output');\n}\n\nconst archiveAndMemory = rollingAndRest[1].split('===MEMORY_ENTRIES===');\nif (archiveAndMemory.length < 2) {\n  throw new Error('Missing ===MEMORY_ENTRIES=== delimiter — check Gemini output');\n}\n\nreturn [{\n  json: {\n    dailyNote:      parts[0].trim(),\n    rollingUpdate:  rollingAndRest[0].trim(),\n    archiveEntries: archiveAndMemory[0].trim(),\n    memoryEntries:  archiveAndMemory[1].trim(),\n    today:          new Date().toISOString().slice(0, 10)\n  }\n}];"
      },
