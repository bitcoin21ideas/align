      "parameters": {
        "jsCode": "const content = items[0].json.content;\nconst sha = items[0].json.sha;\n\nif (!content || items[0].json.error) {\n  return [{ json: { existingContent: '', fileExists: false, sha: '' } }];\n}\n\ntry {\n  const decoded = Buffer.from(content, 'base64').toString('utf-8');\n  return [{ json: { existingContent: decoded, fileExists: true, sha: sha } }];\n} catch(e) {\n  return [{ json: { existingContent: '', fileExists: false, sha: '' } }];\n}"
      },
      "type": "n8n-nodes-base.code",
